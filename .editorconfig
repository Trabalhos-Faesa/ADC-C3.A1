# https://spec.editorconfig.org/

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
charset = utf-8
# spelling_language = pt-BR
trim_trailing_whitespace = true
insert_final_newline = true

# -- Non-standard --
# https://github.com/editorconfig/editorconfig/wiki/EditorConfig-Properties#supported-by-a-limited-number-of-editors
# max_line_length = 120
# https://github.com/editorconfig/editorconfig/wiki/EditorConfig-Properties#ideas-for-domain-specific-properties
# quote_type = single


[Makefile]
# Makefile's use tabs
indent_style = tab

[*.sql]
indent_size = 2
tab_width = 2

# [*.md]
# indent_size = 2
# tab_width = 2

[docker-compose.{yml,yaml}]
indent_size = 2
tab_width = 2
